# .env.example
#
# UdaanAI — Environment Variable Reference
# -----------------------------------------
# Copy this file to .env and fill in your values.
# .env is NEVER committed to version control.
# This file (.env.example) IS committed — values only, no secrets.
#
# Usage:
#   cp .env.example .env
#   # then fill in each value below

# ── Gemini API ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google Cloud APIs ─────────────────────────────────────────────────
# Cloud Text-to-Speech API
GOOGLE_TTS_API_KEY=

# Maps JavaScript API (for booth navigation embed)
GOOGLE_MAPS_API_KEY=

# ── Google Calendar OAuth ─────────────────────────────────────────────
# Get from: GCP Console → APIs & Services → OAuth 2.0 Client IDs
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Firebase Admin SDK ────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Note: paste the private key exactly as given, including \n characters
FIREBASE_PRIVATE_KEY=

# ── Server ────────────────────────────────────────────────────────────
PORT=8080
# Set to your Cloud Run URL in production (no trailing slash)
ALLOWED_ORIGIN=http://localhost:8080
NODE_ENV=development
